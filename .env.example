# ═══ Neo-CohMetrix Configuration ═══

# Server
PORT=8080
NODE_ENV=production

# Anthropic (LLM for L5, L7, L8, L9 analysis)
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Cloud Storage (result persistence)
GCS_BUCKET_NAME=neo-cohmetrix-results
GCS_PROJECT_ID=your-gcp-project-id
# For local dev, set path to service account JSON; on Cloud Run, use default SA
GOOGLE_APPLICATION_CREDENTIALS=./gcs-key.json

# Analysis Settings
MAX_ESSAY_WORDS=50000
MAX_FILE_SIZE_MB=10
ANALYSIS_TIMEOUT_MS=120000

# LLM Settings
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1
LLM_BATCH_SIZE=10

# Composite Score Weights
WEIGHT_F1_NARRATIVITY=0.15
WEIGHT_F2_SYNTAX=0.15
WEIGHT_F3_LEXICAL=0.20
WEIGHT_F4_DEEP_COHESION=0.20
WEIGHT_F5_ARGUMENT=0.20
WEIGHT_F6_STANCE=0.10

# Layer Weights (for LLM-extracted layers, use 0.7x as per spec)
LLM_LAYER_WEIGHT=0.7

# Reader-Adaptive (L10) Defaults
L10_DEFAULT_VOCAB_LEVEL=B2
L10_DEFAULT_DOMAIN_EXPERTISE=Intermediate
L10_ZPD_OPTIMAL_MIN=0.5
L10_ZPD_OPTIMAL_MAX=1.5

# Score Thresholds
THRESHOLD_HIGH=75
THRESHOLD_MID=60
